prefix_rule(pattern=["rm", "-rf", "backend/apps/inventory", "backend/apps/testing", "backend/apps/audit", "backend/apps/core"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "set -euo pipefail\nPY=~/.virtualenvs/device-testlab-api/bin/python\nHOST=127.0.0.1\nPORT=8000\nBASE=\"http://${HOST}:${PORT}\"\n\n$PY manage.py runserver ${HOST}:${PORT} --noreload --nothreading >/tmp/dtl_register_runserver.log 2>&1 &\nPID=$!\ncleanup() { kill \"$PID\" >/dev/null 2>&1 || true; }\ntrap cleanup EXIT\n\nfor i in $(seq 1 30); do\n  if curl -fsS \"${BASE}/api/health/\" >/dev/null 2>&1; then\n    break\n  fi\n  sleep 1\n  if ! kill -0 \"$PID\" >/dev/null 2>&1; then\n    echo \"runserver_exited\" >&2\n    tail -n 200 /tmp/dtl_register_runserver.log >&2 || true\n    exit 1\n  fi\ndone\n\nSTATUS=$(curl -sS -o /dev/null -w '%{http_code}' -X POST \"${BASE}/api/auth/register/\" -H 'Content-Type: application/json' -d '{\"username\":\"x\",\"password\":\"y\"}')\necho \"$STATUS\"\n\nif [[ \"$STATUS\" != \"404\" && \"$STATUS\" != \"405\" ]]; then\n  echo \"Expected 404 or 405, got $STATUS\" >&2\n  exit 1\nfi\n\necho register_disabled_ok\n"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "set -euo pipefail\nPY=~/.virtualenvs/device-testlab-api/bin/python\n# Prepare users\n$PY manage.py shell -c \"from django.contrib.auth import get_user_model; User=get_user_model();\nUser.objects.filter(username__in=['normal','admin']).delete();\nUser.objects.create_user(username='normal', password='normalpass123');\nUser.objects.create_superuser(username='admin', password='adminpass123', email='admin@example.com')\"\n\nHOST=127.0.0.1\nPORT=8000\nBASE=\"http://${HOST}:${PORT}\"\n\n$PY manage.py runserver ${HOST}:${PORT} --noreload --nothreading >/tmp/dtl_users_runserver.log 2>&1 &\nPID=$!\ncleanup() { kill \"$PID\" >/dev/null 2>&1 || true; }\ntrap cleanup EXIT\n\nfor i in $(seq 1 30); do\n  if curl -fsS \"${BASE}/api/health/\" >/dev/null 2>&1; then\n    break\n  fi\n  sleep 1\n  if ! kill -0 \"$PID\" >/dev/null 2>&1; then\n    echo \"runserver_exited\" >&2\n    tail -n 200 /tmp/dtl_users_runserver.log >&2 || true\n    exit 1\n  fi\ndone\n\n# Login normal user\nNORMAL=$(curl -sS -X POST \"${BASE}/api/auth/login/\" -H 'Content-Type: application/json' -d '{\"username\":\"normal\",\"password\":\"normalpass123\"}')\nNORMAL_ACCESS=$(python - <<'PY'\nimport json,sys\nprint(json.loads(sys.stdin.read())['access'])\nPY\n<<<\"$NORMAL\")\n\n# Normal user tries to create user -> 403\nSTATUS=$(curl -sS -o /dev/null -w '%{http_code}' -X POST \"${BASE}/api/users/\" \\\n  -H 'Content-Type: application/json' \\\n  -H \"Authorization: Bearer ${NORMAL_ACCESS}\" \\\n  -d '{\"username\":\"x1\",\"password\":\"xpass123\",\"is_active\":true,\"is_staff\":false,\"is_superuser\":false}')\n\necho \"$STATUS\"\nif [[ \"$STATUS\" != \"403\" ]]; then\n  echo \"Expected 403 for normal user, got $STATUS\" >&2\n  exit 1\nfi\n\necho normal_403_ok\n\n# Login superuser\nADMIN=$(curl -sS -X POST \"${BASE}/api/auth/login/\" -H 'Content-Type: application/json' -d '{\"username\":\"admin\",\"password\":\"adminpass123\"}')\nADMIN_ACCESS=$(python - <<'PY'\nimport json,sys\nprint(json.loads(sys.stdin.read())['access'])\nPY\n<<<\"$ADMIN\")\n\n# Superuser creates user -> 201\nCREATE_RESP=$(curl -sS -i -X POST \"${BASE}/api/users/\" \\\n  -H 'Content-Type: application/json' \\\n  -H \"Authorization: Bearer ${ADMIN_ACCESS}\" \\\n  -d '{\"username\":\"created1\",\"password\":\"createdpass123\",\"is_active\":true,\"is_staff\":false,\"is_superuser\":false}')\n\nSTATUS_LINE=$(printf '%s' \"$CREATE_RESP\" | head -n 1)\nBODY=$(printf '%s' \"$CREATE_RESP\" | awk 'BEGIN{found=0} found{print} /^\\r?$/{found=1}')\n\necho \"$STATUS_LINE\"\necho \"$BODY\"\n\nexport STATUS_LINE BODY\npython - <<'PY'\nimport os,sys,json\nstatus=os.environ['STATUS_LINE']\nbody=os.environ['BODY']\nif ' 201 ' not in status:\n    print('Expected 201, got:',status,'body:',body)\n    sys.exit(1)\nobj=json.loads(body)\nif obj.get('username')!='created1':\n    print('Unexpected response:',obj)\n    sys.exit(1)\nif 'password' in obj:\n    print('Password leaked in response')\n    sys.exit(1)\nprint('admin_201_ok')\nPY\n"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "set -euo pipefail\nPY=~/.virtualenvs/device-testlab-api/bin/python\nHOST=127.0.0.1\nPORT=8000\nBASE=\"http://${HOST}:${PORT}\"\n\n$PY manage.py runserver ${HOST}:${PORT} --noreload --nothreading >/tmp/dtl_perm_runserver.log 2>&1 &\nPID=$!\ncleanup() { kill \"$PID\" >/dev/null 2>&1 || true; }\ntrap cleanup EXIT\n\nfor i in $(seq 1 30); do\n  if curl -fsS \"${BASE}/api/health/\" >/dev/null 2>&1; then\n    break\n  fi\n  sleep 1\n  if ! kill -0 \"$PID\" >/dev/null 2>&1; then\n    echo \"runserver_exited\" >&2\n    tail -n 200 /tmp/dtl_perm_runserver.log >&2 || true\n    exit 1\n  fi\ndone\n\nLOGIN_BODY=$(curl -sS -X POST \"${BASE}/api/auth/login/\" -H 'Content-Type: application/json' -d '{\"username\":\"permuser\",\"password\":\"permpass123\"}')\nACCESS=$(python - <<'PY'\nimport json,sys\nprint(json.loads(sys.stdin.read())['access'])\nPY\n<<<\"$LOGIN_BODY\")\n\nSTATUS_A=$(curl -sS -o /dev/null -w '%{http_code}' \"${BASE}/api/perm/a/\" -H \"Authorization: Bearer ${ACCESS}\")\nSTATUS_B=$(curl -sS -o /dev/null -w '%{http_code}' \"${BASE}/api/perm/b/\" -H \"Authorization: Bearer ${ACCESS}\")\n\necho \"A=${STATUS_A} B=${STATUS_B}\"\nif [[ \"$STATUS_A\" != \"200\" ]]; then\n  echo \"Expected 200 for perm A endpoint, got $STATUS_A\" >&2\n  exit 1\nfi\nif [[ \"$STATUS_B\" != \"200\" ]]; then\n  echo \"Expected 200 for perm B endpoint, got $STATUS_B\" >&2\n  exit 1\nfi\n\necho perm_union_ok\n"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "set -euo pipefail\nPY=~/.virtualenvs/device-testlab-api/bin/python\nHOST=127.0.0.1\nPORT=8000\nBASE=\"http://${HOST}:${PORT}\"\n\n$PY manage.py runserver ${HOST}:${PORT} --noreload --nothreading >/tmp/dtl_perm_runserver.log 2>&1 &\nPID=$!\ncleanup() { kill \"$PID\" >/dev/null 2>&1 || true; }\ntrap cleanup EXIT\n\nfor i in $(seq 1 30); do\n  if curl -fsS \"${BASE}/api/health/\" >/dev/null 2>&1; then\n    break\n  fi\n  sleep 1\n  if ! kill -0 \"$PID\" >/dev/null 2>&1; then\n    echo \"runserver_exited\" >&2\n    tail -n 200 /tmp/dtl_perm_runserver.log >&2 || true\n    exit 1\n  fi\ndone\n\nLOGIN_RESP=$(curl -sS -i -X POST \"${BASE}/api/auth/login/\" -H 'Content-Type: application/json' -d '{\"username\":\"permuser\",\"password\":\"permpass123\"}')\nLOGIN_STATUS=$(printf '%s' \"$LOGIN_RESP\" | head -n 1)\nLOGIN_BODY=$(printf '%s' \"$LOGIN_RESP\" | awk 'BEGIN{found=0} found{print} /^\\r?$/{found=1}')\n\necho \"$LOGIN_STATUS\"\necho \"$LOGIN_BODY\"\n\nexport LOGIN_STATUS LOGIN_BODY\npython - <<'PY'\nimport os,sys,json\nif ' 200 ' not in os.environ['LOGIN_STATUS']:\n    print('login not 200:',os.environ['LOGIN_STATUS'],os.environ['LOGIN_BODY'])\n    sys.exit(1)\nobj=json.loads(os.environ['LOGIN_BODY'])\nprint('login_ok')\nprint('access_len',len(obj['access']))\nPY\n\nACCESS=$(python - <<'PY'\nimport os,json\nprint(json.loads(os.environ['LOGIN_BODY'])['access'])\nPY\n)\n\nSTATUS_A=$(curl -sS -o /dev/null -w '%{http_code}' \"${BASE}/api/perm/a/\" -H \"Authorization: Bearer ${ACCESS}\")\nSTATUS_B=$(curl -sS -o /dev/null -w '%{http_code}' \"${BASE}/api/perm/b/\" -H \"Authorization: Bearer ${ACCESS}\")\n\necho \"A=${STATUS_A} B=${STATUS_B}\"\nif [[ \"$STATUS_A\" != \"200\" ]]; then\n  echo \"Expected 200 for perm A endpoint, got $STATUS_A\" >&2\n  exit 1\nfi\nif [[ \"$STATUS_B\" != \"200\" ]]; then\n  echo \"Expected 200 for perm B endpoint, got $STATUS_B\" >&2\n  exit 1\nfi\n\necho perm_union_ok\n"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "set -euo pipefail\nPY=~/.virtualenvs/device-testlab-api/bin/python\n# Create user without execute_test\n$PY manage.py shell -c \"from django.contrib.auth import get_user_model; User=get_user_model();\nfrom django.contrib.auth.models import Permission\nUser.objects.filter(username='execuser').delete();\nu=User.objects.create_user(username='execuser', password='execpass123');\n# ensure no permission\nu.user_permissions.clear();\nprint('ok')\"\n\nHOST=127.0.0.1\nPORT=8000\nBASE=\"http://${HOST}:${PORT}\"\n\n$PY manage.py runserver ${HOST}:${PORT} --noreload --nothreading >/tmp/dtl_execperm_runserver.log 2>&1 &\nPID=$!\ncleanup() { kill \"$PID\" >/dev/null 2>&1 || true; }\ntrap cleanup EXIT\n\nfor i in $(seq 1 30); do\n  if curl -fsS \"${BASE}/api/health/\" >/dev/null 2>&1; then\n    break\n  fi\n  sleep 1\n  if ! kill -0 \"$PID\" >/dev/null 2>&1; then\n    echo \"runserver_exited\" >&2\n    tail -n 200 /tmp/dtl_execperm_runserver.log >&2 || true\n    exit 1\n  fi\ndone\n\nLOGIN_RESP=$(curl -sS -i -X POST \"${BASE}/api/auth/login/\" -H 'Content-Type: application/json' -d '{\"username\":\"execuser\",\"password\":\"execpass123\"}')\nLOGIN_STATUS=$(printf '%s' \"$LOGIN_RESP\" | head -n 1)\nLOGIN_BODY=$(printf '%s' \"$LOGIN_RESP\" | awk 'BEGIN{found=0} found{print} /^\\r?$/{found=1}')\n\necho \"$LOGIN_STATUS\"\nexport LOGIN_STATUS LOGIN_BODY\npython - <<'PY'\nimport os,sys,json\nif ' 200 ' not in os.environ['LOGIN_STATUS']:\n    print('login not 200:',os.environ['LOGIN_STATUS'],os.environ['LOGIN_BODY'])\n    sys.exit(1)\nprint('login_ok')\nPY\nACCESS=$(python - <<'PY'\nimport os,json\nprint(json.loads(os.environ['LOGIN_BODY'])['access'])\nPY\n)\n\n# Without permission -> 403\nSTATUS1=$(curl -sS -o /dev/null -w '%{http_code}' -X POST \"${BASE}/api/test-tasks/\" -H \"Authorization: Bearer ${ACCESS}\")\necho \"$STATUS1\"\nif [[ \"$STATUS1\" != \"403\" ]]; then\n  echo \"Expected 403 without execute_test, got $STATUS1\" >&2\n  exit 1\nfi\n\n# Grant execute_test\n$PY manage.py shell -c \"from django.contrib.auth import get_user_model; from django.contrib.auth.models import Permission; User=get_user_model();\nu=User.objects.get(username='execuser');\nperm=Permission.objects.get(content_type__app_label='api', codename='execute_test');\nu.user_permissions.add(perm); print('granted')\"\n\n# Now -> 201\nRESP2=$(curl -sS -i -X POST \"${BASE}/api/test-tasks/\" -H \"Authorization: Bearer ${ACCESS}\")\nSTATUS_LINE=$(printf '%s' \"$RESP2\" | head -n 1)\nBODY=$(printf '%s' \"$RESP2\" | awk 'BEGIN{found=0} found{print} /^\\r?$/{found=1}')\n\necho \"$STATUS_LINE\"\necho \"$BODY\"\nexport STATUS_LINE BODY\npython - <<'PY'\nimport os,sys,json\nif ' 201 ' not in os.environ['STATUS_LINE']:\n    print('Expected 201, got:',os.environ['STATUS_LINE'],os.environ['BODY'])\n    sys.exit(1)\nobj=json.loads(os.environ['BODY'])\nif 'id' not in obj:\n    print('Missing id in response',obj)\n    sys.exit(1)\nprint('execute_test_perm_ok')\nPY\n"], decision="allow")
prefix_rule(pattern=["curl", "-sS", "-i", "-H", "Accept: application/json", "http://127.0.0.1:8000/api/auditlogs/"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "$HOME/.virtualenvs/device-testlab-api/bin/python manage.py shell -c \"from django.contrib.auth import get_user_model; U=get_user_model(); print('users', U.objects.count()); print(list(U.objects.values_list('id','username','is_staff','is_superuser')[:10]))\""], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "$HOME/.virtualenvs/device-testlab-api/bin/python manage.py shell -c \"from auditlogs.models import AuditLog; print('auditlogs count', AuditLog.objects.count())\""], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "$HOME/.virtualenvs/device-testlab-api/bin/python manage.py shell -c \"from auditlogs.models import AuditLog; print(list(AuditLog.objects.values_list('id','user_id','username','action_type')[:20]))\""], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "$HOME/.virtualenvs/device-testlab-api/bin/python manage.py shell -c \"from django.contrib.auth import get_user_model; from rest_framework_simplejwt.tokens import RefreshToken; u=get_user_model().objects.get(username='admin'); t=RefreshToken.for_user(u); print('access', str(t.access_token)); print('refresh', str(t))\""], decision="allow")
